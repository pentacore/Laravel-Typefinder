{
    "name": "typefinder/laravel-typefinder",
    "description": "Auto-generate TypeScript type definitions from Laravel Models, Enums, Casts, and Requests.",
    "version": "1.0.0",
    "keywords": ["php", "laravel", "typescript", "types", "models", "enums"],
    "homepage": "https://github.com/laravel-typefinder/laravel-typefinder",
    "authors": [
        {
            "name": "Martin Claesson",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/laravel-typefinder/laravel-typefinder/issues",
        "source": "https://github.com/laravel-typefinder/laravel-typefinder"
    },
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Pentacore\\Typefinder\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Pentacore\\Typefinder\\TypefinderServiceProvider"]
        }
    }
}
