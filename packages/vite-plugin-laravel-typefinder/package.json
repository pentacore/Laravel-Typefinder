{
    "name": "@pentacore/vite-plugin-laravel-typefinder",
    "version": "4.2.0",
    "description": "Vite plugin for Laravel Typefinder — auto-generate TypeScript types from Models, Enums, Casts, and Requests.",
    "keywords": [
        "vite",
        "vite-plugin",
        "laravel",
        "typescript",
        "types"
    ],
    "license": "MIT",
    "homepage": "https://github.com/pentacore/laravel-typefinder",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pentacore/laravel-typefinder.git"
    },
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "dependencies": {
        "picomatch": "^4.0.4"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "^2.0.1",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/picomatch": "^4.0.3",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vite": "^6.4.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.4"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": "Pentacore <contact@pentacore.se>",
    "bugs": {
        "url": "https://github.com/pentacore/Laravel-Typefinder/issues"
    }
}
