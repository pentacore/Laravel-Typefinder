{
    "name": "@pentacore/vite-plugin-laravel-typefinder",
    "version": "4.1.0",
    "description": "Vite plugin for Laravel Typefinder — auto-generate TypeScript types from Models, Enums, Casts, and Requests.",
    "keywords": [
        "vite",
        "vite-plugin",
        "laravel",
        "typescript",
        "types"
    ],
    "license": "MIT",
    "homepage": "https://github.com/pentacore/laravel-typefinder",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pentacore/laravel-typefinder.git"
    },
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "devDependencies": {
        "@codecov/vite-plugin": "^2.0.1",
        "@eslint/js": "^9.0.0",
        "@types/node": "^22.15.17",
        "eslint": "^9.0.0",
        "typescript": "^5.8.0",
        "minimatch": "^10.0.1",
        "typescript-eslint": "^8.0.0",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.1"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": "Pentacore <contact@pentacore.se>",
    "bugs": {
        "url": "https://github.com/pentacore/Laravel-Typefinder/issues"
    }
}
