{
    "name": "@pentacore/vite-plugin-laravel-typefinder",
    "version": "3.0.1",
    "description": "Vite plugin for Laravel Typefinder — auto-generate TypeScript types from Models, Enums, Casts, and Requests.",
    "keywords": [
        "vite",
        "vite-plugin",
        "laravel",
        "typescript",
        "types"
    ],
    "license": "MIT",
    "homepage": "https://github.com/pentacore/laravel-typefinder",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pentacore/laravel-typefinder.git"
    },
    "scripts": {
        "build": "unbuild",
        "dev": "unbuild --stub",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "devDependencies": {
        "@types/node": "^22.15.17",
        "eslint": "^9.0.0",
        "@eslint/js": "^9.0.0",
        "typescript-eslint": "^8.0.0",
        "minimatch": "^10.0.1",
        "rollup": "^4.40.2",
        "typescript": "^5.8.0",
        "unbuild": "^3.5.0",
        "vite": "^6.3.5"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": "Pentacore <contact@pentacore.se>",
    "bugs": {
        "url": "https://github.com/pentacore/Laravel-Typefinder/issues"
    }
}
