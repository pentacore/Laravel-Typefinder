{
    "name": "laravel-typefinder/monorepo",
    "description": "Monorepo for laravel-typefinder and its Vite plugin.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.1|^9.0",
        "phpunit/phpunit": "^11.0|^10.5",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Pentacore\\Typefinder\\": "packages/laravel-typefinder/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "workbench/app/",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": ["@clear", "@prepare"],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "rector": "vendor/bin/rector process"
    }
}
