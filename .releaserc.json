{
  "branches": ["master"],
  "plugins": [
    ["@semantic-release/commit-analyzer", {
      "preset": "conventionalcommits",
      "releaseRules": [
        {
          "type": "build",
          "scope": "deps",
          "release": "patch"
        }
      ]
    }],
    ["@semantic-release/release-notes-generator", {
      "preset": "conventionalcommits",
      "presetConfig": {
        "types": [
          {
            "type": "feat",
            "section": "Features"
          },
          {
            "type": "fix",
            "section": "Bug Fixes"
          },
          {
            "type": "build",
            "section": "Dependencies and Other Build Updates",
            "hidden": false
          }
        ]
      }
    }],
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "node scripts/sync-php-version.mjs ${nextRelease.version}"
    }],
    ["@semantic-release/npm", {
      "pkgRoot": "packages/vite-plugin-laravel-typefinder",
      "npmPublish": false
    }],
    ["@semantic-release/git", {
      "assets": [
        "CHANGELOG.md",
        "package.json",
        "packages/vite-plugin-laravel-typefinder/package.json",
        "packages/laravel-typefinder/src/Version.php",
        "composer.json"
      ],
      "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
    }]
  ]
}
